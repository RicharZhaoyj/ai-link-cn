{
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "**/*.html",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.sh",
      "use": "@vercel/static"
    },
    {
      "src": "**/*.md",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/pricing",
      "dest": "/pricing.html"
    },
    {
      "src": "/api/auth",
      "dest": "/api/auth.py"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/api/auth.py"
    },
    {
      "src": "/api/premium/market/(.*)",
      "dest": "/api/premium/market.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.py"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task"
  },
  "build": {
    "env": {
      "PYTHON_VERSION": "3.9"
    }
  },
  "github": {
    "silent": false,
    "enabled": true,
    "autoAlias": true
  }
}